{"manifest_version":3,"name":"StreamRift","version":"0.6.1","description":"Watch together. Feel together. Synchronize streaming with friends on Netflix, Prime Video, Disney+ and YouTube.","homepage_url":"https://github.com/marcroelans/StreamRift","icons":{"16":"icons/icon16.png","32":"icons/icon32.png","48":"icons/icon48.png","128":"icons/icon128.png"},"action":{"default_popup":"src/popup/index.html","default_icon":{"16":"icons/icon16.png","32":"icons/icon32.png","48":"icons/icon48.png","128":"icons/icon128.png"},"default_title":"StreamRift"},"background":{"service_worker":"src/background/service-worker.js","type":"module"},"content_scripts":[{"matches":["*://*.netflix.com/*"],"js":["src/content/netflix.js"],"run_at":"document_idle"},{"matches":["*://*.primevideo.com/*","*://*.amazon.com/gp/video/*","*://*.amazon.de/gp/video/*"],"js":["src/content/primevideo.js"],"run_at":"document_idle"},{"matches":["*://*.disneyplus.com/*"],"js":["src/content/disneyplus.js"],"run_at":"document_idle"},{"matches":["*://*.youtube.com/*"],"js":["src/content/youtube.js"],"run_at":"document_idle"}],"permissions":["tabs","activeTab","offscreen"],"host_permissions":["*://*.netflix.com/*","*://*.primevideo.com/*","*://*.amazon.com/*","*://*.amazon.de/*","*://*.disneyplus.com/*","*://*.youtube.com/*"]}